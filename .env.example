NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# GitHub API
GITHUB_TOKEN=

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/release_notifications?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=600

# Scanner
SCAN_INTERVAL_SECONDS=300

# Mailer (to be used in notifier step)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional extra
API_KEY=
